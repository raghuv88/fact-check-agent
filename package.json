{
  "name": "fact-check-agent",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "nodemon --exec tsx src/server.ts",
    "fact-check": "tsx src/fact-checker.ts",
    "build": "tsc",
